# BigQuery Credentials
# Option 1: Service account key file path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option 2: Explicit project ID (when using gcloud auth application-default login)
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_ID=ecommerce_dataset

# Customer.io Credentials
CUSTOMERIO_API_KEY=your_customerio_api_key
CUSTOMERIO_SITE_ID=your_customerio_site_id
CUSTOMERIO_TRACK_API_KEY=your_customerio_track_api_key

# Application Settings
LOG_LEVEL=INFO
DEMO_MODE=false

# Output Settings
OUTPUT_DIR=outputs
